### C. Pseudocode — Multimodal Ensemble Inference

```
FUNCTION predict_multimodal(image_bytes, clinical_data):
    // 1. Preprocessing
    image ← open_image(image_bytes).convert("RGB")
    image_tensor ← normalize(resize(to_tensor(image), 224×224), ImageNet_stats)
    clinical_vector ← preprocess_clinical(clinical_data)  // 15-dim normalized
    
    // 2. DenseNet Forward Pass (with Grad-CAM hooks)
    register_hooks(densenet.image_branch.features)
    logits_d ← densenet(image_tensor, clinical_vector)
    probs_d ← sigmoid(logits_d / densenet.temperature)
    top_class_d ← argmax(probs_d[1:]) + 1  // Skip "No Finding"
    backward(logits_d[top_class_d])  // For Grad-CAM
    
    // 3. ResNet Forward Pass
    WITH no_gradients:
        logits_r ← resnet(image_tensor, clinical_vector)
        probs_r ← sigmoid(logits_r / resnet.temperature)
    
    // 4. Gemini Vision LLM Call
    prompt ← format_clinical_prompt(clinical_data)
    gemini_analysis ← gemini_api.generate(image, prompt)
    
    // 5. Max-Confidence Ensemble
    ensemble_probs ← elementwise_maximum(probs_d, probs_r)
    
    // 6. Grad-CAM Heatmap
    pooled_grads ← mean(gradients, dims=[0,2,3])
    heatmap ← ReLU(mean(activations * pooled_grads, dim=1))
    heatmap ← normalize(heatmap) → resize → colorize → blend_with_original
    
    // 7. Risk Score
    risk ← compute_severity_weighted_score(ensemble_probs, thresholds)
    
    // 8. Categorize Findings
    FOR EACH disease_i in [1..13]:
        IF ensemble_probs[i] >= threshold[i]:
            high_priority.append(disease_i)
        ELSE IF ensemble_probs[i] >= threshold[i] * 0.75:
            secondary.append(disease_i)
    
    // 9. Return Complete Payload
    RETURN {
        primary_flag, high_priority, secondary, risk_score,
        heatmap_base64, consensus_panel: {densenet, resnet, gemini}
    }
END FUNCTION
```

### D. Pseudocode — Graph-RAG Query Pipeline

```
FUNCTION graph_rag_query(question, patient_id):
    // 1. Query Augmentation
    augmented ← "Patient medical history, primary diagnosis: " + question
    
    // 2. Vector Encoding
    query_vector ← sentence_bert.encode(augmented)  // 384-dim
    
    // 3. Neo4j Vector Search (patient-scoped)
    results ← neo4j.query(
        "CALL db.index.vector.queryNodes('diagnosis_embeddings', 10, query_vector)
         MATCH (p:Patient {id: patient_id})-[:HAS_DIAGNOSIS]->(event)
         RETURN event.clinical_notes, disease.name, score
         ORDER BY score DESC LIMIT 3"
    )
    
    // 4. Relevance Firewall
    relevant ← FILTER results WHERE score >= 0.70
    IF relevant IS EMPTY:
        RETURN "No relevant data found in your records."
    
    // 5. Context-Grounded Generation
    context ← format_retrieved_context(relevant)
    system_prompt ← "You are MediFlow AI. Use this patient context: " + context
    response ← groq_llm.chat(system_prompt, question)
    
    RETURN {reply: response, sources: relevant}
END FUNCTION
```

